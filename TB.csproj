<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>TB</RootNamespace>
    <AssemblyName>TB</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <UseWinUI>true</UseWinUI>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>

    <!-- ✅ Official Unpackaged CI Properties -->
    <WindowsPackageType>None</WindowsPackageType>
    <DisableMsixProjectCapabilityCheck>true</DisableMsixProjectCapabilityCheck>
    <EnableMsixTooling>false</EnableMsixTooling>
    <DisableWinUIXamlDiagnostics>true</DisableWinUIXamlDiagnostics>
    <GenerateProjectPriFile>false</GenerateProjectPriFile>
    <AppxPackage>false</AppxPackage>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.6.241114003" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2739.15" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.10" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="Core\App.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </ApplicationDefinition>
    <Page Remove="Core\App.xaml" />
    <Content Include="Assets\Fonts\GoogleSans-Regular.ttf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- ✅ Official MSBuild Target Override: Removes ExpandPriContent before evaluation -->
  <Target Name="DisablePriGeneration" BeforeTargets="GenerateProjectPriFile">
    <PropertyGroup>
      <GenerateProjectPriFile>false</GenerateProjectPriFile>
    </PropertyGroup>
    <ItemGroup>
      <_GenerateProjectPriFileDependsOn Remove="ExpandPriContent" />
    </ItemGroup>
  </Target>
</Project>
