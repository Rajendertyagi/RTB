<Application x:Class="TB_Browser.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BgBrush" Color="#202020"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#2C2C2C"/>
            <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
