<Window
    x:Class="TradingBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TradingBrowser.ViewModels"
    xmlns:controls="using:TradingBrowser.Controls"
    xmlns:services="using:TradingBrowser.Services"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    mc:Ignorable="d"
    Title="TradingBrowser">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <SplitView x:Name="MainSplitView" DisplayMode="Overlay" PaneBackground="#CC202124" CompactPaneLength="0" OpenPaneLength="350">
        
        <SplitView.Pane>
            <Pivot Title="Library" Margin="10" Foreground="White">
                <PivotItem Header="Bookmarks">
                    <ListView x:Name="BookmarkListView" SelectionMode="Single" SelectionChanged="BookmarkListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:BookmarkItem">
                                <StackPanel Padding="5">
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Url}" Foreground="Gray" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>
                
                <PivotItem Header="History">
                    <ListView x:Name="HistoryListView" SelectionMode="Single" SelectionChanged="HistoryListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryItem">
                                <StackPanel Padding="5">
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind VisitTime}" Foreground="Gray" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>
            </Pivot>
        </SplitView.Pane>
        
        <Grid x:Name="RootGrid" Background="Transparent" UseLayoutRounding="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="138"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListView x:Name="TabListView" 
                              Grid.Column="0"
                              ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}" 
                              SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                              SelectionChanged="TabListView_SelectionChanged"
                              CanReorderItems="True" AllowDrop="True"
                              ScrollViewer.HorizontalScrollMode="Auto" 
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              Background="Transparent" Padding="0">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TabViewModel">
                                <controls:TabItemPresenter 
                                    Title="{x:Bind Title, Mode=OneWay}"
                                    ContextRequested="Tab_ContextRequested"
                                    MiddleClicked="Tab_MiddleClicked"
                                    CloseClicked="Tab_CloseClicked"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Column="1" Click="NewTab_Click" 
                            Width="28" Height="28" VerticalAlignment="Center" Margin="8,0" 
                            ToolTipService.ToolTip="New Tab (Ctrl+T)" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="White"/>
                    </Button>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Padding="8,0,8,0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Click="Library_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Library" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8F1;" FontSize="14" Foreground="White"/>
                    </Button>
                    <Button Click="Home_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Home" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="White"/>
                    </Button>
                    <Button x:Name="BackButton" Click="Back_Click" Width="28" Height="28" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Back" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White"/>
                    </Button>
                    <Button x:Name="ForwardButton" Click="Forward_Click" Width="28" Height="28" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Forward" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="White"/>
                    </Button>
                    <Button Click="Reload_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Reload" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="White"/>
                    </Button>
                </StackPanel>

                <Border Grid.Column="2" Background="#303134" CornerRadius="20" Height="32" VerticalAlignment="Center">
                    <Grid Padding="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <FontIcon x:Name="OmniboxIcon" Grid.Column="0" Glyph="&#xE721;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        
                        <TextBox x:Name="Omnibox" Grid.Column="1"
                                 Text="{x:Bind ViewModel.OmniboxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 PlaceholderText="Search Google or type a URL"
                                 KeyDown="Omnibox_KeyDown"
                                 Background="Transparent" Foreground="White" BorderThickness="0"
                                 VerticalAlignment="Center" Padding="0" FontSize="14"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <!-- MULTI-PANE: Dedicated Split Button -->
                    <Button Click="SplitPane_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Split Right" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="White"/>
                    </Button>
                    <Button x:Name="BookmarkButton" Click="Bookmark_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Bookmark (Ctrl+D)" Background="Transparent" BorderThickness="0">
                        <FontIcon x:Name="BookmarkIcon" Glyph="&#xE734;" FontSize="14" Foreground="White"/>
                    </Button>
                    
                    <Button Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Downloads" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="White"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <Flyout.SystemBackdrop>
                                    <DesktopAcrylicBackdrop/>
                                </Flyout.SystemBackdrop>
                                <Grid Width="350" MaxHeight="400" Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Downloads" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                                    <ListView Grid.Row="1" ItemsSource="{x:Bind DownloadManager.ActiveDownloads, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="services:ActiveDownload">
                                                <Grid Padding="8" RowSpacing="6" Margin="0,4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                    <ProgressBar Grid.Row="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2"/>
                                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                                        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Command="{x:Bind PauseCommand}" Visibility="{x:Bind PauseVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Pause">
                                                            <FontIcon Glyph="&#xE769;" FontSize="12"/>
                                                        </Button>
                                                        <Button Grid.Column="2" Command="{x:Bind ResumeCommand}" Visibility="{x:Bind ResumeVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Resume">
                                                            <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                                        </Button>
                                                        <Button Grid.Column="3" Command="{x:Bind CancelCommand}" Visibility="{x:Bind CancelVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Cancel">
                                                            <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                                        </Button>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Click="Settings_Click" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Settings" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MULTI-PANE: Split Grid Host -->
            <Grid Grid.Row="2" x:Name="WebViewHost" Background="#202124">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="LeftPaneColumn"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0" x:Name="RightPaneColumn"/>
                </Grid.ColumnDefinitions>

                <!-- Left Pane (Main) -->
                <WebView2 x:Name="MainWebView" Grid.Column="0" DefaultBackgroundColor="Transparent"/>

                <!-- Draggable Divider -->
                <primitives:Thumb x:Name="PaneDivider" Grid.Column="1" Width="4" Background="#303134" Visibility="Collapsed" DragDelta="PaneDivider_DragDelta"/>

                <!-- Right Pane (Secondary) -->
                <Border Grid.Column="2" Background="#202124" x:Name="RightPaneHost" Visibility="Collapsed">
                    <WebView2 x:Name="SecondaryWebView" DefaultBackgroundColor="Transparent"/>
                </Border>
            </Grid>
        </Grid>
    </SplitView>
</Window>
