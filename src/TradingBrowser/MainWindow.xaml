<Window
    x:Class="TradingBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TradingBrowser.ViewModels"
    xmlns:controls="using:TradingBrowser.Controls"
    mc:Ignorable="d"
    Title="TradingBrowser">

    <SplitView x:Name="MainSplitView" DisplayMode="Overlay" PaneBackground="#202124" CompactPaneLength="0" OpenPaneLength="350">
        <SplitView.Pane>
            <Pivot Title="Library" Margin="10" Foreground="White">
                <PivotItem Header="Bookmarks">
                    <ListView x:Name="BookmarkListView" SelectionMode="Single" SelectionChanged="BookmarkListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:BookmarkItem">
                                <StackPanel Padding="5">
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Url}" Foreground="Gray" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>
                <PivotItem Header="History">
                    <ListView x:Name="HistoryListView" SelectionMode="Single" SelectionChanged="HistoryListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryItem">
                                <StackPanel Padding="5">
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind VisitTime}" Foreground="Gray" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>
            </Pivot>
        </SplitView.Pane>
        
        <Grid x:Name="RootGrid" Background="#202124" UseLayoutRounding="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent" Height="36" UseLayoutRounding="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="138"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListView x:Name="TabListView" 
                              Grid.Column="0"
                              ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}" 
                              SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                              SelectionChanged="TabListView_SelectionChanged"
                              CanReorderItems="True" AllowDrop="True"
                              ScrollViewer.HorizontalScrollMode="Enabled" 
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              Background="Transparent" Padding="0">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TabViewModel">
                                <!-- FIX: Removed ContextFlyout to prevent WMC9999 crash due to invalid ElementName binding scope -->
                                <controls:TabItemPresenter 
                                    Title="{x:Bind Title, Mode=OneWay}"
                                    IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                                    IsPinned="{x:Bind IsPinned, Mode=OneWay}"
                                    MiddleClicked="Tab_MiddleClicked"
                                    CloseClicked="Tab_CloseClicked">
                                </controls:TabItemPresenter>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Column="1" Content="+" Click="NewTab_Click" 
                            VerticalAlignment="Center" Margin="4,0" ToolTipService.ToolTip="New Tab (Ctrl+T)" Foreground="White"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Padding="8,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <Button Content="🏠" Click="Home_Click" ToolTipService.ToolTip="Home"/>
                    <Button x:Name="BackButton" Content="←" Click="Back_Click" IsEnabled="False" ToolTipService.ToolTip="Back"/>
                    <Button x:Name="ForwardButton" Content="→" Click="Forward_Click" IsEnabled="False" ToolTipService.ToolTip="Forward"/>
                    <Button Content="⟳" Click="Reload_Click" ToolTipService.ToolTip="Reload"/>
                    <Button x:Name="BookmarkButton" Content="☆" Click="Bookmark_Click" ToolTipService.ToolTip="Bookmark (Ctrl+D)"/>
                    <Button x:Name="DownloadButton" Content="📥" Click="Downloads_Click" ToolTipService.ToolTip="Downloads"/>
                    <Button x:Name="SettingsButton" Content="⚙️" Click="Settings_Click" ToolTipService.ToolTip="Settings"/>
                </StackPanel>

                <TextBox x:Name="Omnibox"
                         Grid.Column="1" 
                         Text="{x:Bind ViewModel.OmniboxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         PlaceholderText="Search Google or type a URL"
                         KeyDown="Omnibox_KeyDown"
                         Background="#303134" Foreground="White" BorderThickness="0"
                         VerticalAlignment="Center" UseLayoutRounding="True"/>
            </Grid>

            <Grid Grid.Row="2" x:Name="WebViewHost" Background="#202124">
                <WebView2 x:Name="MainWebView" DefaultBackgroundColor="Transparent"/>
            </Grid>
        </Grid>
    </SplitView>
</Window>
