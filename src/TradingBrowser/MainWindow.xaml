<Window
    x:Class="TradingBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TradingBrowser.ViewModels"
    xmlns:controls="using:TradingBrowser.Controls"
    xmlns:services="using:TradingBrowser.Services"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d"
    Title="TradingBrowser">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <SplitView x:Name="MainSplitView" DisplayMode="Overlay" PaneBackground="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CompactPaneLength="0" OpenPaneLength="350">
        
        <SplitView.Pane>
            <!-- PHASE 1: 1px Micro-border on Sidebar -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Pivot Title="Library" Margin="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <PivotItem Header="Bookmarks">
                        <ListView x:Name="BookmarkListView" SelectionMode="Single" SelectionChanged="BookmarkListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:BookmarkItem">
                                    <StackPanel Padding="5">
                                        <TextBlock Text="{x:Bind Title}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Url}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>
                    <PivotItem Header="History">
                        <ListView x:Name="HistoryListView" SelectionMode="Single" SelectionChanged="HistoryListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:HistoryItem">
                                    <StackPanel Padding="5">
                                        <TextBlock Text="{x:Bind Title}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind VisitTime}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>
                </Pivot>
            </Border>
        </SplitView.Pane>
        
        <Grid x:Name="RootGrid" Background="Transparent" UseLayoutRounding="True">
            <Grid.Resources>
                <Style x:Key="EdgeToolbarButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Width" Value="32"/>
                    <Setter Property="Height" Value="32"/>
                    <!-- PHASE 1: 4px Corner Geometry for Buttons -->
                    <Setter Property="CornerRadius" Value="4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="ButtonRootGrid" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal"/>
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRootGrid" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRootGrid" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="0.8"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="0.4"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> 
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="138"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListView x:Name="TabListView" Grid.Column="0"
                              automation:AutomationProperties.AutomationId="TabListView"
                              ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}" 
                              SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                              SelectionChanged="TabListView_SelectionChanged"
                              SelectionMode="Extended"
                              CanReorderItems="True" AllowDrop="True"
                              ScrollViewer.HorizontalScrollMode="Auto" 
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              Background="Transparent" Padding="4,0">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinWidth" Value="72"/>
                                <Setter Property="MaxWidth" Value="240"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TabViewModel">
                                <controls:TabItemPresenter 
                                    Title="{x:Bind Title, Mode=OneWay}"
                                    ContextRequested="Tab_ContextRequested"
                                    MiddleClicked="Tab_MiddleClicked"
                                    CloseClicked="Tab_CloseClicked"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Column="1" Click="NewTab_Click" 
                            automation:AutomationProperties.AutomationId="NewTabButton"
                            Style="{StaticResource EdgeToolbarButtonStyle}"
                            VerticalAlignment="Bottom" Margin="4,0,0,4" ToolTipService.ToolTip="New Tab (Ctrl+T)">
                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- PHASE 1: Layer 1 Canvas & 1px Bottom Micro-border -->
            <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button Click="Home_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Home">
                            <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="BackButton" Click="Back_Click" Style="{StaticResource EdgeToolbarButtonStyle}" IsEnabled="False" ToolTipService.ToolTip="Back">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="ForwardButton" Click="Forward_Click" Style="{StaticResource EdgeToolbarButtonStyle}" IsEnabled="False" ToolTipService.ToolTip="Forward">
                            <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button Click="Reload_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Reload">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                    </StackPanel>

                    <!-- PHASE 1: 16px Corner Geometry for Omnibox Container -->
                    <Border x:Name="OmniboxBorder" Grid.Column="2" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="16" Height="32" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                        <Grid Padding="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <FontIcon x:Name="OmniboxIcon" Grid.Column="0" Glyph="&#xE721;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            
                            <TextBox x:Name="Omnibox" Grid.Column="1"
                                     automation:AutomationProperties.AutomationId="Omnibox"
                                     Text="{x:Bind ViewModel.OmniboxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     PlaceholderText="Search Google or type a URL"
                                     KeyDown="Omnibox_KeyDown"
                                     Background="Transparent" Foreground="{ThemeResource TextFillColorPrimaryBrush}" BorderThickness="0"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="0" FontSize="14"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button Click="SplitPane_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Split Right">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="BookmarkButton" Click="Bookmark_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Bookmark (Ctrl+D)">
                            <FontIcon x:Name="BookmarkIcon" Glyph="&#xE734;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        
                        <Button Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Downloads">
                            <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Flyout.SystemBackdrop>
                                        <DesktopAcrylicBackdrop/>
                                    </Flyout.SystemBackdrop>
                                    <!-- PHASE 1: Layer 2 Card Background for Flyouts -->
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                                        <Grid Width="350" MaxHeight="400">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Downloads" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind DownloadManager.ActiveDownloads, Mode=OneWay}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="services:ActiveDownload">
                                                        <Grid Padding="8" RowSpacing="6" Margin="0,4">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                            <ProgressBar Grid.Row="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2"/>
                                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                                                <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1" Command="{x:Bind PauseCommand}" Visibility="{x:Bind PauseVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Pause">
                                                                    <FontIcon Glyph="&#xE769;" FontSize="12"/>
                                                                </Button>
                                                                <Button Grid.Column="2" Command="{x:Bind ResumeCommand}" Visibility="{x:Bind ResumeVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Resume">
                                                                    <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                                                </Button>
                                                                <Button Grid.Column="3" Command="{x:Bind CancelCommand}" Visibility="{x:Bind CancelVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Cancel">
                                                                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                                                </Button>
                                                            </Grid>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <Button Click="Settings_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Settings">
                            <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" x:Name="WebViewHost" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="LeftPaneColumn"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0" x:Name="RightPaneColumn"/>
                </Grid.ColumnDefinitions>

                <WebView2 x:Name="MainWebView" Grid.Column="0" DefaultBackgroundColor="Transparent"/>

                <primitives:Thumb x:Name="PaneDivider" Grid.Column="1" Width="4" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Visibility="Collapsed" DragDelta="PaneDivider_DragDelta"/>

                <Grid Grid.Column="2" x:Name="RightPaneHost" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Button Click="CollapsePane_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Close Split">
                            <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                    </Border>

                    <WebView2 x:Name="SecondaryWebView" Grid.Row="1" DefaultBackgroundColor="Transparent"/>
                </Grid>
            </Grid>
        </Grid>
    </SplitView>
</Window>
