<UserControl
    x:Class="TradingBrowser.Controls.TabItemPresenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="40" MinWidth="72" MaxWidth="240">

    <Grid x:Name="RootGrid" Background="Transparent" Margin="0,4,0,-1" 
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited"
          RightTapped="RootGrid_RightTapped">
        
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ActiveStates">
                <VisualState x:Name="Inactive"/>
                <VisualState x:Name="Active">
                    <VisualState.Setters>
                        <Setter Target="TabBackground.Fill" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                        <Setter Target="TabBackground.Stroke" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                        <Setter Target="TabBackground.CornerRadius" Value="8,8,0,0"/>
                        <Setter Target="BottomCover.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Rectangle x:Name="TabBackground" Fill="Transparent" Stroke="Transparent" StrokeThickness="1" RadiusX="8" RadiusY="8"/>
        <Rectangle x:Name="BottomCover" Fill="{ThemeResource LayerFillColorDefaultBrush}" Height="2" VerticalAlignment="Bottom" Visibility="Collapsed"/>

        <Grid Padding="10,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{x:Bind Title, Mode=OneWay}" 
                       VerticalAlignment="Center" FontSize="12" 
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="1" x:Name="CloseButton" Click="CloseButton_Click" 
                    Width="20" Height="20" MinWidth="20" MinHeight="20" 
                    Padding="0" CornerRadius="4" Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center" Visibility="Collapsed">
                <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
