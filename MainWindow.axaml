<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TB.MainWindow"
        Title="TB"
        Width="1000" Height="600"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        CanResize="True"
        Background="#F8F9FA">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="32"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Title Bar -->
    <Border Grid.Row="0" Background="#E8EAED" PointerPressed="TitleBar_PointerPressed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="TB" Margin="12,0" VerticalAlignment="Center" FontSize="12" FontWeight="Medium" Foreground="#3C4043"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="─" Width="46" Height="32" Click="BtnMin_Click" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#3C4043"/>
          <Button Content="☐" Width="46" Height="32" Click="BtnMax_Click" Background="Transparent" BorderThickness="0" FontSize="12" Foreground="#3C4043"/>
          <Button Content="" Width="46" Height="32" Click="BtnClose_Click" Background="Transparent" BorderThickness="0" FontSize="12" Foreground="#3C4043"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Tab Strip -->
    <TabControl x:Name="TabStrip" 
               Grid.Row="1" 
               ItemsSource="{Binding Tabs}" 
               SelectedItem="{Binding SelectedTab}" 
               SelectionChanged="TabStrip_SelectionChanged">
      <TabControl.ItemTemplate>
        <DataTemplate>
          <Grid Margin="4,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="12" Foreground="#3C4043" Margin="8,0,0,0"/>
            <Button Grid.Column="1" Content="✕" Width="16" Height="16" FontSize="8" Padding="0" Margin="4,0,0,0" Click="TabClose_Click" Background="Transparent" BorderThickness="0" Foreground="#555555"/>
          </Grid>
        </DataTemplate>
      </TabControl.ItemTemplate>
    </TabControl>

    <!-- Navigation Bar -->
    <Border Grid.Row="2" Background="#FFFFFF" Padding="8,6" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="◀" Click="GoBack_Click" Margin="0,0,4,0" Width="32" Height="32"/>
        <Button Grid.Column="1" Content="▶" Click="GoForward_Click" Margin="0,0,4,0" Width="32" Height="32"/>
        <Button Grid.Column="2" Content="⟳" Click="Reload_Click" Margin="0,0,8,0" Width="32" Height="32"/>
        <!-- ✅ Native Avalonia Watermark replaces complex placeholder template -->
        <TextBox x:Name="Omnibox" 
                Grid.Column="3" 
                Watermark="Search or enter web address" 
                KeyDown="Omnibox_KeyDown" 
                Margin="0,0,8,0"/>
        <Button Grid.Column="4" Content="⋮" Click="OpenSettings_Click" Width="32" Height="32"/>
      </Grid>
    </Border>

    <!-- Content Area -->
    <Border Grid.Row="3" Background="#FFFFFF" CornerRadius="8" Margin="8">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text=" UI Shell Ready" FontSize="18" FontWeight="Medium" Foreground="#3C4043"/>
        <TextBlock x:Name="StatusText" Text="Awaiting WebView2 Phase 2" FontSize="12" Foreground="#666666" TextAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
