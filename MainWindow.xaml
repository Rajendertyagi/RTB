<Window x:Class="TB_Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Microsoft.UI.Xaml.Controls"
        Title="TB Browser">
    
    <!-- 1. Define Resources for TextBox Styling -->
    <Window.Resources>
        <Style x:Key="OmniboxTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="ContentElement" 
                                          HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                          IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                          IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                          ZoomMode="{TemplateBinding ScrollViewer.ZoomMode}"
                                          IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                          Margin="{TemplateBinding Padding}"
                                          IsTabStop="False"
                                          AutomationProperties.AccessibilityView="Raw"/>
                            <TextBlock x:Name="PlaceholderTextContentPresenter"
                                       Foreground="#888888"
                                       Margin="{TemplateBinding Padding}"
                                       Text="{TemplateBinding PlaceholderText}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Tabs -->
            <RowDefinition Height="Auto"/> <!-- Address Bar -->
            <RowDefinition Height="*"/>    <!-- Web View -->
        </Grid.RowDefinitions>

        <!-- 2. Tab Bar -->
        <Grid Grid.Row="0" Background="#2d2d2d">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <controls:TabView x:Name="TabView" 
                              AddTabButtonClick="TabView_AddTabButtonClick"
                              TabCloseRequested="TabView_TabCloseRequested"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0,0,0,0"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="MinBtn" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MinBtn_Click" Foreground="#b0b0b0"/>
                <Button x:Name="MaxBtn" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MaxBtn_Click" Foreground="#b0b0b0"/>
                <Button x:Name="CloseBtn" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="CloseBtn_Click" Foreground="#b0b0b0"/>
            </StackPanel>
        </Grid>

        <!-- 3. Address Bar (Fixed Styling) -->
        <Grid Grid.Row="1" Background="#2d2d2d" Padding="6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Nav Buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BackBtn" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="BackBtn_Click" Foreground="#b0b0b0" Margin="0,0,2,0"/>
                <Button x:Name="FwdBtn" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="FwdBtn_Click" Foreground="#b0b0b0" Margin="0,0,2,0"/>
                <Button x:Name="RefBtn" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Width="32" Height="32" Background="Transparent" BorderThickness="0" Click="RefBtn_Click" Foreground="#b0b0b0"/>
            </StackPanel>

            <!-- The "Omnibox" Pill -->
            <Grid Grid.Column="1" Background="#1e1e1e" CornerRadius="20" Margin="4,0" Padding="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Custom Styled TextBox -->
                <TextBox x:Name="UrlBox" 
                         Style="{StaticResource OmniboxTextBoxStyle}"
                         PlaceholderText="Search or enter address"
                         KeyDown="UrlBox_KeyDown" 
                         Width="Auto"
                         HorizontalAlignment="Stretch"/>
                
                <!-- Bookmark Button -->
                <Button Grid.Column="1" Content="&#xE734;" FontFamily="Segoe MDL2 Assets" 
                        Background="Transparent" BorderThickness="0" 
                        Foreground="#b0b0b0" Width="32" Height="32"
                        Click="BookmarkBtn_Click"/>
            </Grid>

            <!-- Menu Button -->
            <Button Grid.Column="2" Content="&#xE712;" FontFamily="Segoe MDL2 Assets" 
                    Width="32" Height="32" Background="Transparent" BorderThickness="0" 
                    Foreground="#b0b0b0" Margin="4,0,0,0"/>
        </Grid>

        <controls:WebView2 x:Name="WebView" Grid.Row="2" NavigationCompleted="WebView_NavigationCompleted"/>
    </Grid>
</Window>
