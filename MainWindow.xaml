<Window x:Class="TB_Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TB Browser" Width="1024" Height="768"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/> <!-- Tab Bar -->
            <RowDefinition Height="40"/> <!-- Address Bar -->
            <RowDefinition Height="*"/>  <!-- Browser -->
        </Grid.RowDefinitions>

        <ContentControl x:Name="TabBarHost" Grid.Row="0"/>
        <ContentControl x:Name="AddressBarHost" Grid.Row="1"/>
        <ContentControl x:Name="BrowserHost" Grid.Row="2"/>
    </Grid>
</Window>
