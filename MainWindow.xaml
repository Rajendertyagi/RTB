<Window x:Class="TB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Microsoft.UI.Xaml.Controls"
        xmlns:wv2="using:Microsoft.Web.WebView2.WinUI"
        xmlns:vm="using:TB.ViewModels"
        x:DataType="local:MainWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Background="#E8EAED">
            <TextBlock Text="TB" Margin="12,0" VerticalAlignment="Center" FontSize="12" FontWeight="Medium" Foreground="#3C4043"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="─" Width="46" Height="32" Click="Minimize_Click" Background="Transparent" BorderThickness="0" Foreground="#3C4043"/>
                <Button Content="☐" Width="46" Height="32" Click="Maximize_Click" Background="Transparent" BorderThickness="0" Foreground="#3C4043"/>
                <Button Content="" Width="46" Height="32" Click="Close_Click" Background="Transparent" BorderThickness="0" Foreground="#3C4043"/>
            </StackPanel>
        </Grid>

        <!-- TabView (SDK 1.8 Correct Properties) -->
        <controls:TabView x:Name="TabView" Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Tabs}"
                          SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                          TabCloseRequested="TabView_TabCloseRequested">
            <controls:TabView.TabItemHeaderTemplate>
                <DataTemplate x:DataType="vm:TabViewModel">
                    <TextBlock Text="{x:Bind Title}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                </DataTemplate>
            </controls:TabView.TabItemHeaderTemplate>
        </controls:TabView>

        <!-- Address Bar -->
        <Grid Grid.Row="2" Background="#FFFFFF" Padding="8,6" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀" Command="{x:Bind NavigationVM.BackCommand}" Margin="0,0,4,0" Width="32" Height="32"/>
            <Button Grid.Column="1" Content="▶" Command="{x:Bind NavigationVM.ForwardCommand}" Margin="0,0,4,0" Width="32" Height="32"/>
            <Button Grid.Column="2" Content="⟳" Command="{x:Bind NavigationVM.ReloadCommand}" Margin="0,0,8,0" Width="32" Height="32"/>
            <TextBox x:Name="Omnibox" Grid.Column="3" PlaceholderText="Search or enter web address"
                     Text="{x:Bind NavigationVM.AddressBarText, Mode=TwoWay}"
                     KeyDown="Omnibox_KeyDown" Margin="0,0,8,0"/>
        </Grid>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="3"/>
    </Grid>
</Window>
