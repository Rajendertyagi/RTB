<Window x:Class="TB_Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Microsoft.UI.Xaml.Controls"
        Title="TB Browser">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <controls:TabView x:Name="TabView" 
                              AddTabButtonClick="TabView_AddTabButtonClick"
                              TabCloseRequested="TabView_TabCloseRequested"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="4,4,0,0"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="MinBtn" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MinBtn_Click"/>
                <Button x:Name="MaxBtn" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MaxBtn_Click"/>
                <Button x:Name="CloseBtn" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="CloseBtn_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Padding="8,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Button x:Name="BackBtn" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Click="BackBtn_Click" Margin="4,0"/>
            <Button x:Name="FwdBtn" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" Click="FwdBtn_Click" Margin="4,0"/>
            <Button x:Name="RefBtn" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Click="RefBtn_Click" Margin="4,0"/>
            <Button x:Name="HomeBtn" Content="&#xE80F;" FontFamily="Segoe MDL2 Assets" Click="HomeBtn_Click" Margin="4,0"/>
            <TextBox x:Name="UrlBox" HorizontalAlignment="Stretch" PlaceholderText="Enter URL..." KeyDown="UrlBox_KeyDown" Margin="8,0"/>
            <Button Content="Go" Click="GoBtn_Click" Style="{StaticResource AccentButtonStyle}" Margin="4,0"/>
        </StackPanel>

        <controls:WebView2 x:Name="WebView" Grid.Row="2" NavigationCompleted="WebView_NavigationCompleted"/>
    </Grid>
</Window>
