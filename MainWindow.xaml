<Window x:Class="TB_Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TB Browser" Width="960" Height="640"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="False"
        Background="{StaticResource FluentBackgroundBrush}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="12" CaptionHeight="32"
                      GlassFrameThickness="-1" UseAeroCaptionButtons="False" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="New"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="Close"/>
        <KeyBinding Key="F5" Command="Refresh"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/> <!-- Tab Bar -->
            <RowDefinition Height="40"/> <!-- Address Bar -->
            <RowDefinition Height="*"/>  <!-- Browser -->
        </Grid.RowDefinitions>

        <ContentControl x:Name="TabBarHost" Grid.Row="0"/>
        <ContentControl x:Name="AddressBarHost" Grid.Row="1"/>
        <ContentControl x:Name="BrowserHost" Grid.Row="2"/>
    </Grid>
</Window>
