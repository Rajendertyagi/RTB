<Window
    x:Class="TB_Browser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:TB_Browser.ViewModels"
    xmlns:models="using:TB_Browser.Models"
    Title="TB Browser">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Draggable TabView Title Bar -->
        <muxc:TabView x:Name="AppTabView"
                      TabItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                      AddTabButtonClick="AppTabView_AddTabButtonClick"
                      TabCloseRequested="AppTabView_TabCloseRequested"
                      Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
            
            <muxc:TabView.TabItemTemplate>
                <DataTemplate x:DataType="vm:TabViewModel">
                    <muxc:TabViewItem Header="{x:Bind Title, Mode=OneWay}">
                        <muxc:TabViewItem.IconSource>
                            <!-- Simple placeholder icon; replace with actual favicon ImageBrush if needed -->
                            <muxc:FontIconSource Glyph="&#xE774;" />
                        </muxc:TabViewItem.IconSource>
                    </muxc:TabViewItem>
                </DataTemplate>
            </muxc:TabView.TabItemTemplate>

            <!-- Custom Window Controls (since native bar is hidden) -->
            <muxc:TabView.TabStripHeader>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                    <Button x:Name="MinimizeBtn" Content="─" Click="WindowBtn_Click" Tag="Minimize" />
                    <Button x:Name="MaximizeBtn" Content="□" Click="WindowBtn_Click" Tag="Maximize" />
                    <Button x:Name="CloseBtn" Content="✕" Click="WindowBtn_Click" Tag="Close" />
                </StackPanel>
            </muxc:TabView.TabStripHeader>
        </muxc:TabView>

        <!-- Row 1: Navigation Toolbar -->
        <Grid Grid.Row="1" Padding="8,4,8,8" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="BackBtn" Click="NavBtn_Click" Tag="Back">
                    <FontIcon Glyph="&#xE72B;" />
                </Button>
                <Button x:Name="ForwardBtn" Click="NavBtn_Click" Tag="Forward">
                    <FontIcon Glyph="&#xE72A;" />
                </Button>
                <Button x:Name="RefreshBtn" Click="NavBtn_Click" Tag="Refresh">
                    <FontIcon Glyph="&#xE72C;" />
                </Button>
            </StackPanel>

            <!-- Address Bar with Autocomplete -->
            <AutoSuggestBox Grid.Column="1"
                            Margin="8,0"
                            Text="{x:Bind ViewModel.NavigationViewModel.AddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{x:Bind ViewModel.NavigationViewModel.Suggestions, Mode=OneWay}"
                            QueryIcon="Find"
                            UpdateTextOnSelect="False"
                            PlaceholderText="Search or enter address"
                            QuerySubmitted="AddressBar_QuerySubmitted"
                            SuggestionChosen="AddressBar_SuggestionChosen"
                            TextChanged="AddressBar_TextChanged" />

            <!-- Settings & Menu -->
            <Button Grid.Column="2" x:Name="SettingsBtn">
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <local:SettingsFlyoutContent DataContext="{x:Bind ViewModel.SettingsViewModel, Mode=OneWay}" />
                    </Flyout>
                </Button.Flyout>
                <FontIcon Glyph="&#xE713;" />
            </Button>
        </Grid>

        <!-- Row 2: WebView2 -->
        <muxc:WebView2 x:Name="BrowserWebView" Grid.Row="2" />
    </Grid>
</Window>
