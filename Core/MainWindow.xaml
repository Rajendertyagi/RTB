<Window x:Class="TB.Core.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="TB" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource ControlFillColorDefaultBrush}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ✅ Placeholder style for standard WPF TextBox -->
        <Style x:Key="PlaceholderTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PlaceholderText" 
                                       Text="{TemplateBinding Tag}" 
                                       Foreground="Gray" 
                                       Margin="12,0" 
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       FontFamily="{StaticResource DefaultFont}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="TB" Margin="12,0" VerticalAlignment="Center" FontSize="12" FontWeight="Medium"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="─" Width="40" Height="32" Click="BtnMin_Click" WindowChrome.IsHitTestVisibleInChrome="True" Background="Transparent" BorderThickness="0"/>
                <Button Content="☐" Width="40" Height="32" Click="BtnMax_Click" WindowChrome.IsHitTestVisibleInChrome="True" Background="Transparent" BorderThickness="0"/>
                <Button Content="✕" Width="40" Height="32" Click="BtnClose_Click" WindowChrome.IsHitTestVisibleInChrome="True" Background="Transparent" BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- Navigation Bar -->
        <Border Grid.Row="1" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8,6" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="◀" Click="GoBack_Click" Margin="0,0,4,0" Width="32" Height="32"/>
                <Button Grid.Column="1" Content="▶" Click="GoForward_Click" Margin="0,0,4,0" Width="32" Height="32"/>
                <Button Grid.Column="2" Content="⟳" Click="Reload_Click" Margin="0,0,8,0" Width="32" Height="32"/>
                <!-- ✅ Standard TextBox with placeholder via Tag + style -->
                <TextBox x:Name="Omnibox" Grid.Column="3" Tag="Search or enter web address" Style="{StaticResource PlaceholderTextBox}" KeyDown="Omnibox_KeyDown" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="⋮" Click="OpenSettings_Click" Width="32" Height="32"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl x:Name="TabStrip" Grid.Row="2" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" SelectionChanged="TabStrip_SelectionChanged" Style="{StaticResource ChromeTabControl}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}" Margin="8,2" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="✕" Width="18" Height="18" FontSize="9" Padding="0" Margin="4,0,0,0" Click="TabClose_Click" />
                    </Grid>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="BrowserView" Grid.Row="2" Margin="0,28,0,0" />
    </Grid>
</Window>
