<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ChromeTabActiveBg" Color="#35363a"/>
    <SolidColorBrush x:Key="ChromeTabInactiveBg" Color="#292a2d"/>
    <SolidColorBrush x:Key="ChromeNavBg" Color="#202124"/>
    <SolidColorBrush x:Key="ChromeAddressBg" Color="#303134"/>
    <SolidColorBrush x:Key="ChromeText" Color="#e8eaed"/>
    <SolidColorBrush x:Key="ChromeAccent" Color="#8ab4f8"/>
    <SolidColorBrush x:Key="ChromeHover" Color="#3c4043"/>
    <SolidColorBrush x:Key="ChromeDisabled" Color="#5f6368"/>

    <Style x:Key="ChromeNavBtn" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="34"/><Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource ChromeText}"/><Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="17">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ChromeHover}"/></Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="{StaticResource ChromeDisabled}"/></Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ChromeTabBtn" TargetType="{x:Type Button}">
        <Setter Property="MinWidth" Value="80"/><Setter Property="MaxWidth" Value="240"/><Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="{StaticResource ChromeTabInactiveBg}"/><Setter Property="Foreground" Value="{StaticResource ChromeText}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="10,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8 8 0 0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChromeNewTabBtn" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="34"/><Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource ChromeText}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ChromeHover}"/></Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
