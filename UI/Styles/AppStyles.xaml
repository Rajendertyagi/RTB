<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="DefaultFont">ms-appx:///Assets/Fonts/GoogleSans-Regular.ttf#Google Sans, Segoe UI</FontFamily>
    <Style TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}"><Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/></Style>
    <Style TargetType="Button"><Setter Property="CornerRadius" Value="8"/></Style>
    <Style TargetType="TextBox"><Setter Property="CornerRadius" Value="16"/></Style>
    <Style TargetType="AutoSuggestBox"><Setter Property="CornerRadius" Value="16"/></Style>
</ResourceDictionary>
