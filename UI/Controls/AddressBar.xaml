<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="32"/>
            <ColumnDefinition Width="Auto" MinWidth="32"/>
            <ColumnDefinition Width="Auto" MinWidth="32"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" MinWidth="60"/>
        </Grid.ColumnDefinitions>
        
        <Button Grid.Column="0" x:Name="BackBtn" Content="←" Style="{DynamicResource NavBtn}" Click="Back_Click" Margin="0,0,2,0" IsEnabled="False" ToolTip="Back"/>
        <Button Grid.Column="1" x:Name="FwdBtn" Content="→" Style="{DynamicResource NavBtn}" Click="Forward_Click" Margin="2,0,2,0" IsEnabled="False" ToolTip="Forward"/>
        <Button Grid.Column="2" x:Name="ReloadBtn" Content="⟳" Style="{DynamicResource NavBtn}" Click="Reload_Click" Margin="2,0,8,0" ToolTip="Reload"/>
        
        <Border Grid.Column="3" Background="#303134" CornerRadius="18" Padding="12,6" Margin="0,2">
            <TextBox x:Name="UrlBox" Background="Transparent" Foreground="#fff" BorderThickness="0" VerticalAlignment="Center" 
                     KeyDown="Url_KeyDown" TextChanged="Url_TextChanged" FontSize="13"/>
        </Border>
        
        <Button Grid.Column="4" Content="Go" Background="{StaticResource AccentBlue}" Foreground="#fff" BorderThickness="0" 
                Padding="20,8" Margin="8,0,0,0" Click="Go_Click" FontSize="13" FontWeight="SemiBold">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1557b0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#0f4a8a"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
