<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="←" Style="{StaticResource NavBtn}" Click="Back_Click" Margin="0,0,4,0"/>
        <Button Grid.Column="1" Content="→" Style="{StaticResource NavBtn}" Click="Forward_Click" Margin="0,0,4,0"/>
        <Button Grid.Column="2" Content="⟳" Style="{StaticResource NavBtn}" Click="Reload_Click" Margin="0,0,4,0"/>
        
        <!-- WPF: CornerRadius via Border wrapper -->
        <Border Grid.Column="3" Background="#303134" CornerRadius="18" Padding="8,4" Margin="0,2">
            <TextBox x:Name="UrlBox" Background="Transparent" Foreground="#fff" BorderThickness="0" 
                     VerticalAlignment="Center" KeyDown="Url_KeyDown"/>
        </Border>
        
        <Button Grid.Column="4" Content="Go" Background="#5f6368" Foreground="#fff" BorderThickness="0" 
                Padding="16,6" Margin="8,0,0,0" Click="Go_Click">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
